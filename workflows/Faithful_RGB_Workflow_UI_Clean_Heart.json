              "Node name for S&R": "GLSLShader"
            },
            "widgets_values": [
              "#version 300 es\nprecision highp float;\n\nuniform sampler2D u_image0; // RealESRGAN base\nuniform sampler2D u_image1; // UltraSharp donor\nuniform float u_float0;     // detail boost (0.0 - 1.5), default 0.65\nuniform float u_float1;     // detail threshold (0.0 - 0.05), default 0.012\nuniform float u_float2;     // shadow cleanup strength (0.0 - 1.0), default 0.65\nuniform float u_float3;     // structure blend (0.0 - 1.0), default 0.35\n\nconst float LARGE_SHADOW_SUPPRESSION = 0.70;\n\nin vec2 v_texCoord;\nlayout(location = 0) out vec4 fragColor0;\n\nfloat lum(vec3 c) {\n    return dot(c, vec3(0.2126, 0.7152, 0.0722));\n}\n\nvec4 blur3x3(sampler2D tex, vec2 uv, vec2 texel) {\n    vec4 blur = vec4(0.0);\n    blur += texture(tex, uv + texel * vec2(-1.0, -1.0)) * 1.0;\n    blur += texture(tex, uv + texel * vec2( 0.0, -1.0)) * 2.0;\n    blur += texture(tex, uv + texel * vec2( 1.0, -1.0)) * 1.0;\n    blur += texture(tex, uv + texel * vec2(-1.0,  0.0)) * 2.0;\n    blur += texture(tex, uv) * 4.0;\n    blur += texture(tex, uv + texel * vec2( 1.0,  0.0)) * 2.0;\n    blur += texture(tex, uv + texel * vec2(-1.0,  1.0)) * 1.0;\n    blur += texture(tex, uv + texel * vec2( 0.0,  1.0)) * 2.0;\n    blur += texture(tex, uv + texel * vec2( 1.0,  1.0)) * 1.0;\n    return blur / 16.0;\n}\n\nvoid main() {\n    vec2 texel = 1.0 / vec2(textureSize(u_image1, 0));\n\n    vec4 base = texture(u_image0, v_texCoord);\n    vec4 donor = texture(u_image1, v_texCoord);\n    vec4 smallBlur = blur3x3(u_image1, v_texCoord, texel);\n\n    // Wider low-frequency estimate to catch broad bad shadows / halos.\n    vec4 wideBlur = (\n        texture(u_image1, v_texCoord) * 4.0 +\n        texture(u_image1, v_texCoord + texel * vec2( 2.0,  0.0)) +\n        texture(u_image1, v_texCoord + texel * vec2(-2.0,  0.0)) +\n        texture(u_image1, v_texCoord + texel * vec2( 0.0,  2.0)) +\n        texture(u_image1, v_texCoord + texel * vec2( 0.0, -2.0))\n    ) / 8.0;\n\n    vec3 highDetail = donor.rgb - smallBlur.rgb;\n    float detailEnergy = max(max(abs(highDetail.r), abs(highDetail.g)), abs(highDetail.b));\n    float edgeMask = smoothstep(u_float1, u_float1 * 4.0, detailEnergy);\n\n    float baseLuma = lum(base.rgb);\n    float donorLuma = lum(donor.rgb);\n    float wideLuma = lum(wideBlur.rgb);\n\n    // If UltraSharp creates an over-dark region relative to the base or surrounding area,\n    // suppress it so icons and simple textures do not regain the bad baked shadows.\n    float darkHalo = max(max(wideLuma - donorLuma, 0.0), max(baseLuma - donorLuma, 0.0));\n    float shadowReject = 1.0 - smoothstep(0.02, 0.14, darkHalo) * LARGE_SHADOW_SUPPRESSION;\n\n    // Also reduce donor influence in naturally dark regions.\n    float darkProtect = mix(1.0, smoothstep(0.08, 0.40, baseLuma), u_float2);\n\n    float keepMask = edgeMask * shadowReject * darkProtect;\n\n    // Use RealESRGAN as the clean base, then re-introduce only a controlled amount of\n    // UltraSharp structure and micro-detail where it is actually safe and useful.\n    vec3 structureMix = mix(base.rgb, donor.rgb, u_float3 * keepMask);\n    vec3 result = structureMix + highDetail * u_float0 * keepMask;\n\n    fragColor0 = vec4(clamp(result, 0.0, 1.0), base.a);\n}\n",
